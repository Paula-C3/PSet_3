@startuml sequence_diagram

actor Operator
participant API as "API\nController"
participant UseCases as "IncidentUseCases"
participant Repository as "IncidentRepository"
participant DB as "Database"
participant EventBus as "EventBus"
participant Observer as "NotificationObserver"
participant Factory as "NotificationFactory"
participant Template as "Template\nMethod"
participant Command as "Command"
participant Repo2 as "NotificationRepository"

Operator -> API: POST /incidents\n(titulo, descripcion, severidad)
activate API

API -> UseCases: create_incident(data, creator_id)
activate UseCases

UseCases -> Repository: save(incident)
activate Repository

Repository -> DB: INSERT incident
activate DB
DB --> Repository: incident_id
deactivate DB

Repository --> UseCases: incident con id
deactivate Repository

UseCases -> EventBus: publish(INCIDENT_CREATED, {id, title})
activate EventBus

EventBus -> Observer: update(INCIDENT_CREATED, data)
activate Observer

Observer -> Factory: create_command(notification)
activate Factory

Factory --> Observer: SendEmailCommand
deactivate Factory

Observer -> Template: build_message(notification)
activate Template

Template --> Observer: mensaje formateado
deactivate Template

Observer -> Command: execute()
activate Command

Command -> Repo2: save(notification)
activate Repo2

Repo2 -> DB: INSERT notification\n(status=SENT)
activate DB
DB --> Repo2: notification_id
deactivate DB

Repo2 --> Command: notification guardada
deactivate Repo2

Command --> Observer: success
deactivate Command

Observer --> EventBus: completado
deactivate Observer

EventBus --> UseCases: evento procesado
deactivate EventBus

UseCases --> API: incident
deactivate UseCases

API --> Operator: HTTP 201\njson(incident)
deactivate API

Operator <- Operator: Ve confirmación del\nincidente creado

@enduml
